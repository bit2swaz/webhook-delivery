# copy this file to .env and fill in your values
# do not commit .env to version control

PORT=8000

# async url used by fastapi (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/webhooks

# sync url used by celery workers (psycopg2 driver)
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/webhooks

# test database - used by pytest fixtures
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/webhooks_test

REDIS_URL=redis://localhost:6379/0

# generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production

# jwt access token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# max webhook delivery attempts before marking dead (includes initial attempt)
MAX_DELIVERY_ATTEMPTS=6

# set to "true" to run alembic upgrade head on startup (dev only)
RUN_MIGRATIONS_ON_START=false
